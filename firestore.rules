rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Chaque utilisateur ne peut lire/écrire que ses propres personnages
    match /users/{userId}/characters/{characterId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Sections de notes
      match /noteSections/{sectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notes individuelles
      match /noteItems/{noteId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Bloquer tout autre accès
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
